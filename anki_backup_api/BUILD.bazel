localstack_image(
    name = "local",
    handler_jars = [
        ":create-backup-handler_deploy.jar",
        ":find-backups-handler_deploy.jar",
        ":get-backup-handler_deploy.jar",
        ":update-backup-handler_deploy.jar",
    ],
    init_resources = "src/test/resources/init_resources.py",
    repo_tag = "bazel/anki-backup-local:latest",
)


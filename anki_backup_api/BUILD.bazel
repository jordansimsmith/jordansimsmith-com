pkg_tar(
    name = "local-handlers.tar",
    testonly = True,
    srcs = [
        ":create-backup-handler_deploy.jar",
        ":find-backups-handler_deploy.jar",
        ":get-backup-handler_deploy.jar",
        ":update-backup-handler_deploy.jar",
    ],
    package_dir = "/opt/code/localstack/",
)

pkg_tar(
    name = "local-init-resources.tar",
    testonly = True,
    srcs = ["src/test/resources/init_resources.py"],
    package_dir = "/etc/localstack/init/ready.d/",
)

oci_image(
    name = "local-image",
    testonly = True,
    base = "@localstack//:localstack",
    env = {
        "LOCALSTACK_LAMBDA_IGNORE_ARCHITECTURE": 1,
        "LOCALSTACK_LAMBDA_KEEPALIVE_MS": 0,
    },
    tars = [
        ":local-init-resources.tar",
        ":local-handlers.tar",
    ],
)

oci_load(
    name = "local-load",
    testonly = True,
    image = ":local-image",
    repo_tags = [
        "bazel/anki-backup-local:latest",
    ],
)

